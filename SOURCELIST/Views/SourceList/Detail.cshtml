@model sourcelist.Models.ViewModels.SourceListDetailViewModel

@{
    ViewData["Title"] = "SourceList Detail";

    var status = Model.SourceListStatus?.Trim().ToUpper() ?? "PENDING";
    var statusConfig = status switch
    {
        "PENDING" => (Class: "status-btn-PENDING", Icon: "bi-hourglass-split"),
        "APPROVED" => (Class: "status-btn-APPROVED", Icon: "bi-check-circle"),
        "REJECTED" => (Class: "status-btn-REJECTED", Icon: "bi-x-circle"),
        "CANCELED" => (Class: "status-btn-CANCELED", Icon: "bi-slash-circle"),
        _ => (Class: "status-btn-DEFAULT", Icon: "bi-question-circle"),
    };
}

@section Head {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">


    <style>
        .section-header {
            background-color: #a3d65c;
            color: #fff;
            padding: 10px 15px;
            font-weight: bold;
            border-radius: 6px 6px 0 0;
            margin-bottom: 10px;
        }

        /* .data-block {
            border: 1px solid #dee2e6;
            border-top: 0;
            padding: 15px;
            background-color: #fff;
        } */

        .data-row {
            display: flex;
            flex-wrap: wrap;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

            .data-row label {
                width: 220px;
                font-weight: 600;
                color: #495057;
                padding: 5px 0;
            }

            .data-row .value {
                flex: 1;
                min-width: 200px;
                padding: 5px 10px;
                background-color: #f8f9fa;
                border: 1px solid #e9ecef;
                border-radius: 4px;
                color: #212529;
            }

        .status-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.9em;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 600;
            border: none;
            cursor: default;
        }

        .status-btn-PENDING {
            background: #fff3cd;
            color: #856404;
        }

        .status-btn-APPROVED {
            background: #d4edda;
            color: #155724;
        }

        .status-btn-REJECTED {
            background: #f8d7da;
            color: #721c24;
        }

        .status-btn-CANCELED {
            background: #e2e3e5;
            color: #383d41;
        }

        .status-btn-DEFAULT {
            background: #d6d8db;
            color: #383d41;
        }

        .fixed-bottom-right {
            position: fixed;
            right: 20px;
            bottom: 20px;
            z-index: 1030;
            display: flex;
            gap: 0.5rem;
        }

        .select2.period {
            max-width: 250px;
            width: 100%;
        }
    </style>
}

<div class="container-fluid p-4" style="font-family:Calibri;">

    @* <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0">SourceList Detail: <strong>@Model.SourceListNumber</strong></h4>
        <span class="@statusConfig.Class status-btn">
            <i class="bi @statusConfig.Icon"></i> @Model.SourceListStatus
        </span>
    </div> *@

        <div class="section-header d-flex justify-content-between align-items-center">
            <span>Submission Information</span>
            <span style="font-size:0.9em;">
                Submit Date: @(Model.SubmittedDate?.ToString("dd-MMM-yyyy") ?? "-")
            </span>
        </div>
        <div class="data-block">
            <div class="data-row"><label>Requestor</label><div class="value">@Model.Requestor</div></div>
            <div class="data-row"><label>BAU No. / Part Number</label><div class="value">@Model.BAUNumber</div></div>
            <div class="data-row"><label>Part Description</label><div class="value">@Model.PartDescription</div></div>
            <div class="data-row"><label>Supplier Name</label><div class="value">@Model.SupplierName</div></div>
            <div class="data-row"><label>Vendor Code</label><div class="value">@Model.VendorCode</div></div>
            <div class="data-row"><label>Supplier Status</label><div class="value">@Model.SupplierStatus</div></div>
            <div class="data-row"><label>Source List Status</label><div class="value">@Model.SourceListStatus</div></div>
            <div class="data-row"><label>CMS# of Final CRB</label><div class="value">@Model.CMSFinalCRB</div></div>
            <div class="data-row"><label>Reason of Submission</label><div class="value">@Model.ReasonSubmission</div></div>
        </div>

    <div class="section-header mt-4">
        <span>Attachments</span>
    </div>
    <div class="data-block attachments">
        @if (!string.IsNullOrEmpty(Model.AttachmentFileName))
        {
            <div class="mb-2">
                <a href="@Url.Action("DownloadFile", "SourceList", new { id = Model.SourceListNumber, fileName = Model.AttachmentFileName })">
                    <i class="bi bi-download"></i> @System.IO.Path.GetFileName(Model.AttachmentFileName)
                </a>
                @* <small class="text-muted d-block">Supplier Assessment Form</small> *@
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.AttachedEndorsement))
        {
            <div class="mb-2">
                <a href="@Url.Action("DownloadFile", "SourceList", new { id = Model.SourceListNumber, fileName = Model.AttachedEndorsement })">
                    <i class="bi bi-download"></i> @System.IO.Path.GetFileName(Model.AttachedEndorsement)
                </a>
                @* <small class="text-muted d-block">Supplier Endorsement List</small> *@
            </div>
        }

        @if (string.IsNullOrEmpty(Model.AttachmentFileName) && string.IsNullOrEmpty(Model.AttachedEndorsement))
        {
            <span class="text-muted">No attachments available.</span>
        }
    </div>

            <div class="section-header mt-4">
                <span>Approval Information</span>
            </div>
            <div class="data-block">
                <div class="data-row"><label>Approver Name</label><div class="value">@Model.ApproverName</div></div>
                <div class="data-row"><label>Approver Email</label><div class="value">@Model.ApproverEmail</div></div>
            </div>
 
 @if (ViewBag.ShowApprovalButtons as bool? == true)
    {
        <div class="data-block">
            <div class="data-row">
            <label for="validityPeriod">Validity period:</label>

            <select id="validityPeriod" class="form-select value period select2" style="background-color:white; max-width: 250px;">
                <option value="">-- Select --</option>
                <option value="Temporary">Temporary</option>
                <option value="Permanent">Permanent</option>
            </select>
        </div>
    </div>
    }
        

    <div class="fixed-bottom-right">
        <button type="button" class="btn btn-primary" id="btnCopyLink"><i class="bi bi-clipboard"></i> Copy Link</button>

        @if (ViewBag.ShowApprovalButtons as bool? == true)
        {
            <button type="button" class="btn btn-success" id="btnApprove"><i class="bi bi-check-circle"></i> APPROVE</button>
            <button type="button" class="btn btn-danger" id="btnReject"><i class="bi bi-x-circle"></i> REJECT</button>
        }
        
        <a href="@ViewData["ReturnUrl"]" class="btn btn-secondary"><i class="bi bi-arrow-left-circle"></i> Back to List</a>
    </div>


</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(function() {
            // UNTUK TOMBOL APPROVE
            $('#btnApprove').on('click', function () {
                const validityPeriod = $('#validityPeriod').val();
                if (!validityPeriod) {
                    Swal.fire('Validation Error', 'Please select a validity period!', 'error');
                    return; 
                }

                Swal.fire({
                    title: 'Are you sure?',
                    text: "You are about to approve this request.",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Approve!',
                    confirmButtonColor: '#28a745',
                }).then((result) => {
                    if (result.isConfirmed) {
                        const dataToSend = {
                            SourceListNumber: '@Model.SourceListNumber',
                            ValidityPeriod: validityPeriod
                        };
                        $.ajax({
                            url: '@Url.Action("Approve", "SourceList")',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(dataToSend),
                            success: function(response) {
                                Swal.fire('Approved!', response.message, 'success')
                                    .then(() => window.location.href = '@ViewData["ReturnUrl"]');
                            },
                            error: function() {
                                Swal.fire('Error!', 'An unknown error occurred.', 'error');
                            }
                        });
                    }
                });
            });

            // UNTUK TOMBOL REJECT
            $('#btnReject').on('click', function() {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You are about to reject this request.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Reject!',
                    confirmButtonColor: '#d33',
                }).then((result) => {
                    if (result.isConfirmed) {
                        const dataToSend = {
                            SourceListNumber: '@Model.SourceListNumber'
                        };
                        $.ajax({
                            url: '@Url.Action("Reject", "SourceList")',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(dataToSend),
                            success: function(response) {
                                Swal.fire('Rejected!', response.message, 'success')
                                    .then(() => window.location.href = '@ViewData["ReturnUrl"]');
                            },
                            error: function() {
                                Swal.fire('Error!', 'An unknown error occurred.', 'error');
                            }
                        });
                    }
                });
            });

            // UNTUK TOMBOL COPY LINK
            $('#btnCopyLink').on('click', function() {
                navigator.clipboard.writeText(window.location.href).then(() => {
                    Swal.fire({
                        icon: 'success',
                        title: 'Link Copied!',
                        showConfirmButton: false,
                        timer: 1500
                    });
                }, (err) => {
                    console.error('Could not copy text: ', err);
                    Swal.fire('Oops!', 'Failed to copy the link.', 'error');
                });
            });

        });
    </script>
}