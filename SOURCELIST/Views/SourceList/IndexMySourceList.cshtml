@model sourcelist.Services.PagedResult<sourcelist.DTOs.SourceListDTO>

@{
    ViewData["Title"] = "My SourceList";
    string searchTerm = ViewBag.SearchTerm ?? "";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="~/Style/tablebadgecss.css" rel="stylesheet" />
}

<div class="container-fluid p-4" style="font-family:Calibri;">
    <div class="form-header">
        <i class="bi bi-clipboard-check"></i> My SourceList
    </div>

    <form id="searchForm" class="mb-3" autocomplete="off">
        <div class="input-group">
            <input type="text" id="searchBox" class="form-control" placeholder="Search... " name="searchTerm" value="@searchTerm" autocomplete="off">
        </div>
    </form>

    <div id="sourceListTableContainer">
        @await Html.PartialAsync("_MySourceListTable", Model)
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $(document).on('click', '.pagination a', function(e) {
                e.preventDefault();

             
                var page = $(this).data('page');
                var searchTerm = $("#searchInput").val();

         
                $('#sourceListTableContainer').html('<p class="text-center">Loading...</p>');

                $.ajax({
                    url: '@Url.Action("IndexMySourceList")',
                    type: 'GET',
                    data: {
                        page: page,
                        searchTerm: searchTerm,
                        isAjax: true
                    },
                    success: function(response) {
                        $('#sourceListTableContainer').html(response);
                    },
                    error: function() {
                        // Tampilkan pesan error jika gagal
                        $('#sourceListTableContainer').html('<p class="text-center text-danger">Failed to load data.</p>');
                    }
                });
            });
        });
    </script>
}
