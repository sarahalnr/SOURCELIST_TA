@model List<sourcelist.DTOs.SourceListDTO>

@{
    ViewData["Title"] = "My SourceList";
    string searchTerm = ViewBag.SearchTerm ?? "";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="~/Style/tablebadgecss.css" rel="stylesheet" />
}

<div class="container-fluid p-4" style="font-family:Calibri;">
    <div class="form-header">
        <i class="bi bi-clipboard-check"></i> My SourceList
    </div>

    <form id="searchForm" class="mb-3" autocomplete="off">
        <div class="input-group">
            <input type="text" id="searchBox" class="form-control" placeholder="Search... " name="searchTerm" value="@searchTerm" autocomplete="off">
        </div>
    </form>

    <div id="sourceListTableContainer">
        @await Html.PartialAsync("_MySourceListTable", Model)
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function() {
            let typingTimer;
            const doneTypingInterval = 500;

            function loadTable(page = 1) {
                let searchTerm = $('#searchBox').val();
                let url = '@Url.Action("IndexMySourceList", "SourceList")';

                $('#sourceListTableContainer').html('<div class="text-center">Loading...</div>');

                $.get(url, {
                    page: page,
                    searchTerm: searchTerm,
                    isAjax: true
                }, function (data) {
                    $('#sourceListTableContainer').html(data);
                });
            }

            $('#searchBox').on('keyup', function () {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(() => loadTable(1), doneTypingInterval);
            });

            // Pagination AJAX
            $(document).on('click', '.pagination .page-link', function (e) {
                e.preventDefault();
                let page = $(this).data('page');
                if (page && !$(this).parent().hasClass('disabled') && !$(this).parent().hasClass('active')) {
                    loadTable(page);
                }
            });
        });
    </script>
}