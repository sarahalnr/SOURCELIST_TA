@model sourcelist.Services.PagedResult<sourcelist.DTOs.SourceListDTO>

@{
    ViewData["Title"] = "All SourceList";
    string searchTerm = ViewBag.SearchTerm ?? "";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="~/Style/tablebadgecss.css" rel="stylesheet" />
}

<div class="container-fluid p-4" style="font-family:Calibri;">
    <div class="form-header">
        <i class="bi bi-clipboard-check"></i> All Sourcelist
    </div>

    <form id="searchForm" class="mb-3" autocomplete="off">
        <div class="input-group">
            <input type="text" id="searchBox" class="form-control" placeholder="Search by Requestor and Date ... " name="searchTerm" value="@searchTerm" autocomplete="off">
        </div>
    </form>

    <div id="sourceListTableContainer">
        @await Html.PartialAsync("_MySourceListTable", Model)
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        let typingTimer;
        const doneTypingInterval = 500;


       function loadSourceList(page = 1) {
    let searchTerm = $('#searchBox').val();
    $('#sourceListTableContainer').html('<p class="text-center">Loading...</p>');

    $.ajax({ 
        url: '@Url.Action("AllSourceList")',
        type: 'GET',
        data: {
            page: page,
            searchTerm: searchTerm,
            isAjax: true
        },
        success: function (data) {
            $('#sourceListTableContainer').html(data);
        },
        error: function (xhr, status, error) {
      
            if (xhr.status === 401) {
                Swal.fire({
                    title: 'Oops!',
                    text: 'Sesi Anda telah berakhir. Anda akan diarahkan ke halaman Home.',
                    icon: 'error',
                    confirmButtonText: 'OK'
                }).then(() => {
                    window.location.href = '@Url.Action("Index", "Home")';
                });
            } else {
                $('#sourceListTableContainer').html('<p class="text-center text-danger">Gagal memuat data.</p>');
            }
        }
    });
}
        $('#searchBox').on('keyup', function () {
            clearTimeout(typingTimer);
            typingTimer = setTimeout(function () {
                loadSourceList(1);
            }, doneTypingInterval);
        }).on('keydown', function () {
            clearTimeout(typingTimer);
        });


        $(document).on('click', '#sourceListTableContainer .pagination .page-link', function (e) {
            e.preventDefault();
            let page = $(this).data('page');
            if (page && !$(this).parent().hasClass('disabled') && !$(this).parent().hasClass('active')) {
                loadSourceList(page);
            }
        });
    </script>
}