@model sourcelist.Models.ViewModels.SourceListDetailViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Source List Report - @Model.SourceListNumber</title>
    <style>
        body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        font-size: 10pt;
        color: #333;
        background-color: #fff;
        margin: 0px; 
        padding: 20px;
        }

        /* Header Laporan */
        .report-header {
        border-bottom: 2px solid #345E37;
        padding-bottom: 8px;
        margin-bottom: 15px;
        }

        .report-title {
        font-size: 14pt;
        font-weight: bold;
        color: #345E37;
        margin: 0;
        }

        .report-sub {
        font-size: 10pt;
        color: #345E37;
        margin-top: 2px;
        }

        table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
        }

        td, th {
        padding: 6px 8px;
        border: 1px solid #ccc;
        vertical-align: top; 
        }

        /* Style Header Kolom */
        .label-style {
        background-color: #f0f2f5; 
        font-weight: bold;
        color: #444;
        }

        .info-label {
        width: 140px;
        }
        .reason-cell {
        height: 50px;       
        vertical-align: top; 
        }

        /* Tabel Approver */
        .approver-header {
        background-color: #f0f2f5;
        color: #444;
        font-weight: bold;
        text-align: left;
        }

        /* Footer */
        .footer {
        margin-top: 20px;
        text-align: right;
        font-size: 8pt;
        color: #888;
        border-top: 1px solid #eee;
        padding-top: 5px;
        }
    </style>
</head>
<body>

    <div class="report-header">
        <h1 class="report-title">Source List Report</h1>
        <div class="report-sub">Document No: <strong>@Model.SourceListNumber</strong></div>
    </div>

    <table>
        <tr>
            <td class="label-style info-label">Requestor</td>
            <td>@Model.Requestor</td>

            <td class="label-style info-label">Vendor Code</td>
            <td>@Model.VendorCode</td>
        </tr>
        <tr>
            <td class="label-style info-label">BAU No. / Part</td>
            <td>@Model.BAUNumber</td>

            <td class="label-style info-label">Supplier Status</td>
            <td>@Model.SupplierStatus</td>
        </tr>
        <tr>
            <td class="label-style info-label">Part Description</td>
            <td>@Model.PartDescription</td>

            <td class="label-style info-label">Sourcelist Status</td>
            <td>@Model.SourceListStatus</td>
        </tr>
        <tr>
            <td class="label-style info-label">Supplier Name</td>
            <td>@Model.SupplierName</td>

            <td class="label-style info-label">CMS# of final CRB</td>
            <td>@Model.CMSFinalCRB</td>
        </tr>
        <tr>
            <td class="label-style info-label">Reason of Submission</td>
            <td colspan="3" class="reason-cell"> 
                @if(string.IsNullOrEmpty(Model.ReasonSubmission))
                {
                    <span style="color:#999; font-style:italic;">-</span>
                }
                else
                {
                    @Model.ReasonSubmission
                }
            </td>
        </tr>
    </table>

    <table>
        <thead>
            <tr>
                <th class="approver-header" style="width: 20%;">Approver Name</th>
                <th class="approver-header" style="width: 25%;">Email</th>
                <th class="approver-header" style="width: 15%;">Status</th>
                <th class="approver-header" style="width: 15%;">Validity Period</th>
                <th class="approver-header" style="width: 25%;">Remarks</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.ApproverName</td>
                <td>@Model.ApproverEmail</td>
                <td>
                    @if(Model.ApproverStatus == "REJECTED") {
                        <span style="color:red; font-weight:bold;">@Model.ApproverStatus</span>
                    } else if (Model.ApproverStatus == "APPROVED") {
                        <span style="color:green; font-weight:bold;">@Model.ApproverStatus</span>
                    } else if (Model.ApproverStatus == "PENDING") {
                        <span style="color:orangered; font-weight:bold;">@Model.ApproverStatus</span>
                    } else {
                        @Model.ApproverStatus
                    }
                </td>
                <td>@Model.ValidityPeriod</td>
                <td>@Model.Remarks</td>
            </tr>
        </tbody>
    </table>

    <div class="footer">
        Generated on: @DateTime.Now.ToString("dd-MMM-yyyy HH:mm")
    </div>

</body>
</html>