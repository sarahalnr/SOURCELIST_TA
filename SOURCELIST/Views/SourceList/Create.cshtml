@using Newtonsoft.Json
@{
    var userInfoJson = Context.Session.GetString("UserInfo");
    UserInfo userInfo = null;
    if (!string.IsNullOrEmpty(userInfoJson))
    {
        userInfo = JsonConvert.DeserializeObject<UserInfo>(userInfoJson);
    }
    ViewData["Title"] = "Sourcelist Request";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        main[role="main"] {
            height: 100%;
            overflow-y: auto;
            padding: 2rem !important;
        }
      
        .form-header {
            background-color: #a3d65c;
            color: white;
            padding: 10px;
            font-weight: bold;
            font-size: 18px;
            margin-bottom: 1.5rem;
        }

        .row .col-form-label {
            display: flex;
            align-items: center;
            font-weight: 600;
            padding-right: 0;
        }

        input[disabled] {
            background-color: #e9ecef;
            cursor: not-allowed;
        }

        .textarea-tall {
            height: 120px; /*mengatur tinggi text area*/
        }

        .select.input-error + .select2-container--bootstrap-5 .select2-selection {
            border-color: #e74c3c !important;
        }

        .input-error {
            border-color: #e74c3c !important; 
        }

        .file-input-wrapper {
            position: relative;
            width: 100%;
        }

        .file-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.375rem 0.75rem;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background-color: #fff;
            cursor: pointer;
            height: calc(1.5em + .75rem + 2px);
        }

            .file-display.disabled {
                background-color: #e9ecef;
                cursor: not-allowed;
            }

        .file-clear-button {
            background: none;
            border: none;
            color: #6c757d;
            cursor: pointer;
            padding: 0;
            font-size: 1.2rem;
        }

        #supplierAssessmentForm {
            display: none; 
        }

        .input-error + .select2-container--bootstrap-5 .select2-selection {
            border-color: #e74c3c !important;
        }
    </style>
}

<form id="sourcelistForm" novalidate>
    <div class="form-header">
        Sourcelist request
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="row mb-3 align-items-center">
                <label for="requestor" class="col-sm-3 col-form-label">Requestor</label>
                <div class="col-sm-9">
                    <input type="text" id="requestor" class="form-control" disabled="disabled" value="@userInfo?.FullName">
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="bauNo" class="col-sm-3 col-form-label">BAU No. / Part Number</label>
                <div class="col-sm-9">
                    <input type="text" id="bauNo" class="form-control" required>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="partDesc" class="col-sm-3 col-form-label">Part Description</label>
                <div class="col-sm-9">
                    <input type="text" id="partDesc" class="form-control" required>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="supplierName" class="col-sm-3 col-form-label">Supplier Name</label>
                <div class="col-sm-9">
                    <input type="text" id="supplierName" class="form-control" required>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="vendorCode" class="col-sm-3 col-form-label">Vendor Code</label>
                <div class="col-sm-9">
                    <input type="text" id="vendorCode" class="form-control" required>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="supplierStatus" class="col-sm-3 col-form-label">Supplier status</label>
                <div class="col-sm-5">
                    <select id="supplierStatus" class="form-select" required>
                        <option selected value=""></option>
                        <option value="New">New</option>
                        <option value="Existing">Existing</option>
                    </select>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="sourceListStatus" class="col-sm-3 col-form-label">Source list status</label>
                <div class="col-sm-5">
                    <select id="sourceListStatus" class="form-select" required>
                        <option selected></option>
                        <option value="New">New</option>
                        <option value="Extend">Extend</option>
                    </select>
                </div>
            </div>

            <div class="row mb-3 align-items-center">
                <label class="col-sm-3 col-form-label">Supplier Assesment Form</label>
                <div class="col-sm-9">
                    <div class="file-input-wrapper">
                        <input type="file" id="supplierAssessmentForm" accept=".pdf" disabled>
                        <div id="fileDisplay" class="file-display disabled">
                            <span id="fileName">No file chosen (PDF file)</span>
                            <button type="button" id="fileClear" class="file-clear-button" style="display: none;">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-3 align-items-center">
                <label for="cmsFinalCrb" class="col-sm-3 col-form-label">CMS# of Final CRB</label>
                <div class="col-sm-9">
                    <input type="text" id="cmsFinalCrb" class="form-control" required>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="row mb-3">
                <label for="reasonSubmission" class="col-sm-2 col-form-label pt-0">Reason of Submission</label>
                <div class="col-sm-10">
                    <textarea id="reasonSubmission" class="form-control textarea-tall" required></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="form-header mt-4">
        Approval
    </div>
    <div class="row">
        <div class="col-md-4">
            <div class="mb-3">
                <label for="approverDropdown" class="form-label fw-bold">Approver</label>

                <div class="input-group">
                    <select id="approverDropdown" class="form-select" required></select>
                    <button type="button" id="addApproverBtn" class="btn btn-success" style="margin-left: 8px; border-radius:8px;">Add Approver</button>
                </div>
            </div>
        </div>
    </div>

    <table id="approvalTable" class="table table-hover mt-3" style="width: 60%; display: none;">
        <thead class="table-light">
            <tr>
                <th style="width: 40%;">Approver Name</th>
                <th style="width: 40%;">Email</th>
                <th style="width: 20%;">Action</th>
            </tr>
        </thead>
        <tbody>
        </tbody>
    </table>

    <div class="d-flex justify-content-end mt-4">
        <button type="button" class="btn btn-primary" id="btnSubmit">Submit</button>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
         
            const supplierStatusSelect = $('#supplierStatus');
            const assessmentFormInput = $('#supplierAssessmentForm');
            const fileDisplay = $('#fileDisplay');
            const fileNameSpan = $('#fileName');
            const fileClearButton = $('#fileClear');

            function toggleAssessmentForm() {
                if (supplierStatusSelect.val() === 'New') {
                    assessmentFormInput.prop('disabled', false);
                    fileDisplay.removeClass('disabled');
                } else {
                    assessmentFormInput.prop('disabled', true);
                    fileDisplay.addClass('disabled');
                    // Reset file jika dinonaktifkan
                    assessmentFormInput.val('');
                    fileNameSpan.text('No file chosen (PDF file)');
                    fileClearButton.hide();
                }
            }

            toggleAssessmentForm();
            supplierStatusSelect.on('change', toggleAssessmentForm);

            fileDisplay.on('click', function(e) {
                if (!$(this).hasClass('disabled') && !$(e.target).is(fileClearButton.find('i'))) {
                    assessmentFormInput.click();
                }
            });

            //  Saat file di input lama berubah, perbarui kolom input
            assessmentFormInput.on('change', function() {
                if (this.files && this.files.length > 0) {
                    fileNameSpan.text(this.files[0].name);
                    fileClearButton.show();
                } else {
                    fileNameSpan.text('No file chosen (PDF file)');
                    fileClearButton.hide();
                }
            });
            // Saat tombol silang diklik, reset semuanya
            fileClearButton.on('click', function() {
                assessmentFormInput.val('');
                fileNameSpan.text('No file chosen (PDF file)');
                $(this).hide();
            });

             $('#supplierStatus, #sourceListStatus').select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: "-- select --"
            });

            let approvalList = [];
            const addApproverBtn = $('#addApproverBtn');
            const approverDropdown = $('#approverDropdown');

          
            approverDropdown.select2({
                theme: 'bootstrap-5',
                placeholder: '-- Search Approver --',
                allowClear: true,
                minimumInputLength: 3,
                ajax: {
                    url: '@Url.Action("SearchApprovers", "SourceList")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) { return { term: params.term }; },
                    processResults: function (data) { return { results: data }; }
                },
                templateResult: function (data) {
                    if (!data.id) return data.text;
                    return $(`<div><strong>${data.text}</strong><br><small>${data.email || ''}</small></div>`);
                },
                templateSelection: function (data) {
                    return data.text;
                }
            });

            // untuk button "Add Approver"
            addApproverBtn.on('click', function() {
                if (approvalList.length > 0) {
                    return;
                }

                const selectedApprover = approverDropdown.select2('data')[0];

                if (!selectedApprover || !selectedApprover.id) {
                    Swal.fire('Oops...', 'Please select an approver first!', 'warning');
                    return;
                }

                approvalList.push({
                    ApproverId: selectedApprover.id,
                    ApproverName: selectedApprover.text,
                    ApproverEmail: selectedApprover.email,
                    ApproverBadge: selectedApprover.desc
                });

                updateApprovalTable();
                approverDropdown.val(null).trigger('change');
            });

            // mengatur tombol disable
            function updateApprovalTable() {
                const tbody = $('#approvalTable tbody');
                tbody.empty();

                if (approvalList.length > 0) {
                    $('#approvalTable').show();
                    approvalList.forEach((item, index) => {
                        tbody.append(`
                            <tr>
                                <td>${item.ApproverName}</td>
                                <td>${item.ApproverEmail}</td>
                                <td><button type="button" class="btn btn-danger btn-sm" onclick="removeApproval(${index})">Remove</button></td>
                            </tr>
                        `);
                    });

                    // Jika sudah ada approver, nonaktifkan dropdown dan tombol
                    addApproverBtn.prop('disabled', true);
                    approverDropdown.prop('disabled', true);

                } else {
                    $('#approvalTable').hide();

                    // Jika approver kosong, aktifkan kembali dropdown dan tombol
                    addApproverBtn.prop('disabled', false);
                    approverDropdown.prop('disabled', false);
                }
            }

            // Fungsi untuk menghapus approver 
            window.removeApproval = function(index) {
                approvalList.splice(index, 1);
                updateApprovalTable(); 
            }

             // Event handler untuk menghapus border merah saat input diisi
            $('#sourcelistForm [required]').on('input change', function () {
                if ($(this).val() && $(this).val().trim() !== "") {
                    $(this).removeClass("input-error");
                    if ($(this).is('select')) {
                        $(this).next('.select2-container').find('.select2-selection').removeClass('input-error');
                    }
                }
            });

            //  button submit
            $('#btnSubmit').on('click', function() {
                const fieldsToValidate = [
                    { id: 'bauNo', label: 'BAU No. / Part Number' },
                    { id: 'partDesc', label: 'Part Description' },
                    { id: 'supplierName', label: 'Supplier Name' },
                    { id: 'vendorCode', label: 'Vendor Code' },
                    { id: 'supplierStatus', label: 'Supplier status' },
                    { id: 'sourceListStatus', label: 'Source list status' },
                    { id: 'cmsFinalCrb', label: 'CMS# of Final CRB' },
                    { id: 'reasonSubmission', label: 'Reason of Submission' }
                ];

                let emptyFields = [];
                fieldsToValidate.forEach(field => {
                    const el = $('#' + field.id);
                    el.removeClass('input-error');
                    if (el.is('select')) { el.next('.select2-container').find('.select2-selection').removeClass('input-error'); }

                    if (!el.val() || el.val().trim() === '') {
                        emptyFields.push(field.label);
                        el.addClass('input-error');
                        if (el.is('select')) { el.next('.select2-container').find('.select2-selection').addClass('input-error'); }
                    }
                });

                // Validasi approver
                if (approvalList.length === 0) {
                    emptyFields.push('Approver');
                    $('#approverDropdown').next('.select2-container').find('.select2-selection').addClass('input-error');
                }

                if (emptyFields.length > 0) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Data Tidak Lengkap',
                        html: 'Data tersebut wajib diisi:<br><ul style="text-align:left; list-style-position: inside;">' + emptyFields.map(f => `<li>${f}</li>`).join('') + '</ul>'
                    });
                    return; 
                }

                // Jika validasi lolos, lanjutkan konfirmasi
                Swal.fire({
                    title: 'konfirmasi',
                    text: "Apakah Anda yakin semua data sudah benar??",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, Submit!'
                }).then((result) => {
                    if (result.isConfirmed) {

                        Swal.fire('Submitted!', 'Permintaan Anda telah dikirimkan.', 'success');
                    }
                });
            });
        });
    </script>
}

