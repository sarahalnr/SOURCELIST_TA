@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
    
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        main[role="main"] {
            height: 100%;
            overflow-y: auto;
            padding: 2rem !important;
        }

        .form-header {
            background-color: #a3d65c;
            color: white;
            padding: 10px;
            font-weight: bold;
            font-size: 18px;
            margin-bottom: 1.5rem;
        }

        .row .col-form-label {
            display: flex;
            align-items: center;
            font-weight: 600;
            padding-right: 0;
        }

        input[disabled] {
            background-color: #e9ecef;
            cursor: not-allowed;
        }

        .textarea-tall {
            height: 120px;
        }

        .input-error, .input-error + .select2-container--bootstrap-5 .select2-selection {
            border-color: #e74c3c !important;
        }

        .file-input-wrapper {
            position: relative;
            width: 100%;
        }

        .file-display {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.375rem 0.75rem;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            background-color: #fff;
            cursor: pointer;
            height: calc(1.5em + .75rem + 2px);
        }

            .file-display.disabled {
                background-color: #e9ecef;
                cursor: not-allowed;
            }

        .file-clear-button {
            background: none;
            border: none;
            color: #6c757d;
            cursor: pointer;
            padding: 0;
            font-size: 1.2rem;
        }


        #supplierAssessmentForm, #endorsementForm {
            display: none;
        }
    </style>
}

<form id="sourcelistForm" novalidate>
    @Html.AntiForgeryToken()
    <div class="form-header">
        Sourcelist request
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="row mb-3 align-items-center">
                <label for="requestor" class="col-sm-3 col-form-label">Requestor</label>
                <div class="col-sm-9">
                    <input type="text" id="requestor" name="Requestor" class="form-control" disabled="disabled" value="@User.Identity.Name">
                </div>
             </div>
            <div class="row mb-3 align-items-center">
                <label for="supplierStatus" class="col-sm-3 col-form-label">Supplier status</label>
                <div class="col-sm-9">
                    <select id="supplierStatus" name="SupplierStatus" class="form-select" required>
                        <option value="">-- Select --</option>
                        <option value="New Supplier">New</option>
                        <option value="Existing Supplier">Existing</option>
                        <option value="Transfer from another site">Transfer</option>
                    </select>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="sourceListStatus" class="col-sm-3 col-form-label">Source list status</label>
                <div class="col-sm-9">
                    <select id="sourceListStatus" name="SourceListStatus" class="form-select" required>
                        <option value="">-- Select --</option>
                        <option value="New">New</option>
                        <option value="Extend">Extend</option>
                    </select>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="supplierName" class="col-sm-3 col-form-label">Supplier Name</label>
                <div class="col-sm-9" id="supplier-container">
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="vendorCode" class="col-sm-3 col-form-label">Vendor Code</label>
                <div class="col-sm-9">
                    <input type="text" id="vendorCode" name="VendorCode" class="form-control" required>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="bauNo" class="col-sm-3 col-form-label">BAU No. / Part Number</label>
                <div class="col-sm-9"><input type="text" id="bauNo" name="BAUNumber" class="form-control" required></div>
            </div>
            <div class="row mb-3 align-items-center">
                <label for="partDesc" class="col-sm-3 col-form-label">Part Description</label>
                <div class="col-sm-9"><input type="text" id="partDesc" name="PartDescription" class="form-control" required></div>
            </div>
          
            <div class="row mb-3 align-items-center">
                <label class="col-sm-3 col-form-label">Supplier Assesment Form</label>
                <div class="col-sm-9">
                    <div class="file-input-wrapper">
                        <input type="file" id="supplierAssessmentForm" name="AssessmentAttachmentFile" accept=".pdf" disabled>
                        <div id="assessmentFileDisplay" class="file-display disabled">
                            <span id="assessmentFileName">Choose File (PDF file)</span>
                            <button type="button" id="assessmentFileClear" class="file-clear-button" style="display: none;"><i class="bi bi-x"></i></button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row mb-3 align-items-center">
                <label class="col-sm-3 col-form-label">Supplier Endorsement List</label>
                <div class="col-sm-9">
                    <div class="file-input-wrapper">
                        <input type="file" id="endorsementForm" name="AttachedEndorsementFile" accept=".pdf" disabled>
                        <div id="endorsementFileDisplay" class="file-display disabled">
                            <span id="endorsementFileName">Choose File (PDF file)</span>
                            <button type="button" id="endorsementFileClear" class="file-clear-button" style="display: none;"><i class="bi bi-x"></i></button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-3 align-items-center"><label for="cmsFinalCrb" class="col-sm-3 col-form-label">CMS# of Final CRB</label><div class="col-sm-9"><input type="text" id="cmsFinalCrb" name="CMSFinalCRB" class="form-control" required></div></div>
        </div>
    </div>
    <div class="row"><div class="col-lg-12"><div class="row mb-3"><label for="reasonSubmission" class="col-sm-2 col-form-label pt-0">Reason of Submission</label><div class="col-sm-10"><textarea id="reasonSubmission" name="ReasonSubmission" class="form-control textarea-tall" required></textarea></div></div></div></div>

    @* <div class="form-header mt-4">Approval</div> *@
    @* <div class="row"><div class="col-md-4"><div class="mb-3"><label for="approverDropdown" class="form-label fw-bold">Approver</label><div class="input-group"><select id="approverDropdown" class="form-select" required></select><button type="button" id="addApproverBtn" class="btn btn-success" style="margin-left: 8px; border-radius:8px;">Add Approver</button></div></div></div></div> *@
    @* <table id="approvalTable" class="table table-hover mt-3" style="width: 60%; display: none;"><thead class="table-light"><tr><th style="width: 40%;">Approver Name</th><th style="width: 40%;">Email</th><th style="width: 20%;">Action</th></tr></thead><tbody></tbody></table> *@
    <div class="d-flex justify-content-end mt-4"><button type="button" class="btn btn-primary" id="btnSubmit">Submit</button></div>
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function() {
            // --- DEKLARASI VARIABEL (HANYA SEKALI) ---
            const form = $('#sourcelistForm');
            const supplierStatusSelect = $('#supplierStatus');
            const supplierContainer = $('#supplier-container'); // Target div yang sudah kita beri ID
            const vendorCodeInput = $('#vendorCode');

            const assessmentFileInput = {
                input: $('#supplierAssessmentForm'),
                display: $('#assessmentFileDisplay'),
                fileName: $('#assessmentFileName'),
                clearButton: $('#assessmentFileClear')
            };

            const endorsementFileInput = {
                input: $('#endorsementForm'),
                display: $('#endorsementFileDisplay'),
                fileName: $('#endorsementFileName'),
                clearButton: $('#endorsementFileClear')
            };

            function toggleSupplierFields() {
                const status = supplierStatusSelect.val();
                supplierContainer.empty(); 

                if (status === 'New Supplier') {
                    supplierContainer.html('<input type="text" id="supplierName" name="SupplierName" class="form-control" required placeholder="Masukkan Nama Supplier Baru">');
                    vendorCodeInput.prop('disabled', false).val('');
                } else if (status === 'Existing Supplier' || status === 'Transfer from another site') {
                    supplierContainer.html('<select id="supplierNameDropdown" name="SupplierId" class="form-select" required></select>');
                    vendorCodeInput.prop('disabled', true).val('');

                    $('#supplierNameDropdown').select2({
                        theme: 'bootstrap-5',
                        placeholder: "-- Choose Supplier --",
                        allowClear: true,
                        ajax: {
                            url: '@Url.Action("GetSuppliers", "SourceList")', 
                            dataType: 'json',
                            processResults: function (data) {
                                return { results: data };
                            }
                        }
                    });
                } else {
                    supplierContainer.html('<input type="text" class="form-control" disabled placeholder="Please select a Supplier Status first."">');
                    vendorCodeInput.prop('disabled', true).val('');
                }
            }

            function setupFileInput(fileSet) {
                fileSet.display.on('click', function (e) {
                    if (!$(this).hasClass('disabled') && !$(e.target).closest(fileSet.clearButton).length) {
                        fileSet.input.click();
                    }
                });
                fileSet.input.on('change', function () {
                    if (this.files && this.files.length > 0) {
                        fileSet.fileName.text(this.files[0].name);
                        fileSet.clearButton.show();
                        fileSet.display.removeClass('input-error');
                    } else {
                        fileSet.fileName.text('Choose file (PDF file)');
                        fileSet.clearButton.hide();
                    }
                });
                fileSet.clearButton.on('click', function () {
                    fileSet.input.val('').trigger('change');
                });
            }

            function toggleConditionalInputs() {
                const status = supplierStatusSelect.val();
                const manageState = (fileSet, isEnabled) => {
                    fileSet.input.prop('disabled', !isEnabled).prop('required', isEnabled);
                    fileSet.display.toggleClass('disabled', !isEnabled);
                    if (!isEnabled) {
                        fileSet.input.val('').trigger('change');
                        fileSet.display.removeClass('input-error');
                    }
                };
                manageState(assessmentFileInput, status === 'New Supplier');
                manageState(endorsementFileInput, status === 'Transfer from another site');
            }


            // Inisialisasi Select2 untuk dropdown statis
            $('#sourceListStatus, #supplierStatus').select2({
                theme: 'bootstrap-5',
                width: '100%',
                placeholder: "-- Select --",
                allowClear: true,
                minimumResultsForSearch: Infinity
            });

            setupFileInput(assessmentFileInput);
            setupFileInput(endorsementFileInput);

            toggleSupplierFields();
            toggleConditionalInputs();
            supplierStatusSelect.on('change', function() {
                toggleSupplierFields();
                toggleConditionalInputs();
            });

            // Event listener saat dropdown supplier (dinamis) dipilih
            $(document).on('change', '#supplierNameDropdown', function () {
                const supplierId = $(this).val();
                if (supplierId) {
                    $.ajax({
                        url: '@Url.Action("GetSupplierDetail", "SourceList")', 
                        data: { id: supplierId },
                        success: function (data) {
                            if (data && data.kodeVendor) {
                                vendorCodeInput.val(data.kodeVendor);
                            }
                        }
                    });
                } else {
                    vendorCodeInput.val('');
                }
            });

            form.find('[required]').on('input change', function() {
                 if ($(this).val() && $(this).val().trim() !== "") {
                     $(this).removeClass("input-error");
                 }
            });

            // --- EVENT HANDLER TOMBOL SUBMIT ---
            $('#btnSubmit').on('click', function () {
                form.find('.input-error').removeClass('input-error');
                let emptyFields = [];

                // Validasi dinamis untuk supplier name
                const supplierStatus = supplierStatusSelect.val();
                if (supplierStatus === 'New Supplier') {
                    if (!$('#supplierName').val()) {
                        emptyFields.push('Supplier Name');
                        $('#supplierName').addClass('input-error');
                    }
                } else if (supplierStatus === 'Existing Supplier' || supplierStatus === 'Transfer from another site') {
                    if (!$('#supplierNameDropdown').val()) {
                        emptyFields.push('Supplier Name');
                        $('#supplierNameDropdown').next('.select2-container').find('.select2-selection').addClass('input-error');
                    }
                }

                // Validasi field lainnya
                form.find('input[required]:enabled, select[required]:enabled, textarea[required]:enabled').each(function() {
                    const el = $(this);
                    if (!el.val() || el.val().trim() === '') {
                        const label = $(`label[for='${el.attr('id')}']`).text();
                        if (!emptyFields.includes(label) && label) {
                           emptyFields.push(label);
                        }
                        el.addClass('input-error');
                        if (el.is('select')) {
                            el.next('.select2-container').find('.select2-selection').addClass('input-error');
                        }
                    }
                });

                if (emptyFields.length > 0) {
                    Swal.fire({
                        icon: 'warning', title: 'Please fill in all required fields',
                        html: 'The following fields cannot be empty:<br><ul style="text-align:left; list-style-position: inside;">' + emptyFields.map(f => `<li>${f}</li>`).join('') + '</ul>'
                    });
                    return;
                }

                Swal.fire({
                    title: 'Confirmation', text: "Are you sure all the data is correct?", icon: 'question',
                    showCancelButton: true, confirmButtonText: 'Yes, Submit!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#requestor').prop('disabled', false);
                        vendorCodeInput.prop('disabled', false); // Aktifkan sementara agar nilainya ikut terkirim
                        var formData = new FormData(form[0]);
                        $('#requestor').prop('disabled', true);
                        vendorCodeInput.prop('disabled', true); // Nonaktifkan kembali

                        Swal.fire({ title: 'Submitting...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

                        $.ajax({
                            url: '@Url.Action("Create", "SourceList")', type: 'POST', data: formData,
                            processData: false, contentType: false,
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire({ icon: 'success', title: 'Success!', text: response.message })
                                    .then(() => { window.location.href = '@Url.Action("IndexMySourceList", "SourceList")'; });
                                } else {
                                    Swal.fire('Error', response.message, 'error');
                                }
                            },
                            error: function (jqXHR) {
                                const errorMsg = jqXHR.responseJSON?.message || "Terjadi kesalahan yang tidak diketahui.";
                                Swal.fire('Permintaan Gagal', errorMsg, 'error');
                            }
                        });
                    }
                });
            });
        });
    </script>
}