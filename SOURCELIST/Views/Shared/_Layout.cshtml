    @* SweetAlert notification *@
    @{
        var alertType = TempData["SweetAlertType"]?.ToString() ?? "info";
        var alertTitle = alertType switch
        {
            "success" => "Success!",
            "error" => "Oops!",
            "warning" => "Warning!",
            _ => "Info"
        };
        var redirectUrl = TempData["SweetAlertRedirect"]?.ToString() ?? Url.Action("Index", "Home");
    }

    @if (TempData["SweetAlertMessage"] != null)
    {
            <script>
                Swal.fire({
                    title: '@alertTitle',
                    text: '@TempData["SweetAlertMessage"]',
                    icon: '@alertType',
                    confirmButtonText: 'OK'
                }).then(function () {
                    window.location.href = '@redirectUrl';
                });
            </script>
    }
</body>
</html>

