@using Newtonsoft.Json
@using sourcelist.Models

@{
    var userInfoJson = Context.Session.GetString("UserInfo");
    UserInfo userInfo = null;
    if (!string.IsNullOrEmpty(userInfoJson))
    {
        userInfo = JsonConvert.DeserializeObject<UserInfo>(userInfoJson);
    }

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Source List System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/Style/style.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="@Url.Content("~/favicon.png")">

    @RenderSection("Head", required: false)

    <style>
        :root {
            --sidebar-width: 240px;
            --topbar-height: 60px;
            --sidebar-bg: #345E37;
            --sidebar-hover: #A3D65C;
            --topbar-bg: #fff;
            --topbar-text: #355C3A;
            --main-bg: #f4f6f8;
            --main-text: #222e3c;
            --sidebar-text: #fff;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--main-bg);
            color: var(--main-text);
        }

        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--sidebar-bg);
            color: var(--sidebar-text);
            height: 100vh;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            transition: width 0.3s, left 0.3s;
        }

            .sidebar.closed {
                width: 0;
                overflow: hidden;
            }

        .sidebar-header {
            height: var(--topbar-height);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.3rem;
            letter-spacing: 1px;
            box-sizing: border-box;
            padding: 0 20px;
            line-height: 1;
        }

        .sidebar a {
            color: var(--sidebar-text);
            padding: 12px 20px;
            display: flex;
            align-items: center;
            text-decoration: none;
            transition: background-color 0.2s, color 0.2s;
            font-size: 1rem;
            position: relative;
            border-radius: 0 20px 20px 0;
            margin-right: 8px;
        }

            .sidebar a .bi {
                margin-right: 10px;
                font-size: 1.2em;
            }

            .sidebar a:hover, .sidebar a.active {
                background-color: var(--sidebar-hover);
                color: var(--sidebar-bg);
                font-weight: bold;
            }

        .topbar {
            background-color: var(--topbar-bg);
            color: var(--topbar-text);
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            z-index: 10;
            height: var(--topbar-height);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            font-weight: bold;
            border-bottom: 1px solid #e0e0e0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
            box-sizing: border-box;
            transition: left 0.3s;
        }

        .main-content {
            margin-left: var(--sidebar-width);
            flex-grow: 1;
            padding: calc(var(--topbar-height) + 20px) 20px 20px 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: var(--main-bg);
            transition: margin-left 0.3s;
        }

        .sidebar.closed ~ .main-content {
            margin-left: 0;
        }

            .sidebar.closed ~ .main-content .topbar {
                left: 0;
            }

        .sidebar-toggle-btn {
            background: none;
            border: none;
            color: var(--topbar-text);
            font-size: 1.7rem;
            cursor: pointer;
            margin-right: 16px;
            display: flex;
            align-items: center;
        }
    </style>
</head>
<body>
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-header">Source List Web</div>

        @if (User.IsInRole("Requestor") || User.IsInRole("Approver") || User.IsInRole("Admin"))
        {
            <a asp-controller="Home" asp-action="Index"
               class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")">
                <i class="bi bi-house-door"></i><span>Home</span>
            </a>
        }

        @if (User.IsInRole("Requestor"))
        {
            <a asp-controller="SourceList" asp-action="Create"
               class="@(currentController == "SourceList" && currentAction == "Create" ? "active" : "")">
                <i class="bi bi-plus-circle-dotted"></i><span>New Source List</span>
            </a>
            <a asp-controller="SourceList" asp-action="IndexMySourceList"
               class="@(currentController == "SourceList" && currentAction == "IndexMySourceList" ? "active" : "")">
                <i class="bi bi-person-lines-fill"></i><span>My Source List</span>
            </a>
        }

        @if (User.IsInRole("Approver"))
        {
            <a asp-controller="SourceList" asp-action="IndexForApprove"
               class="@(currentController == "SourceList" && currentAction == "IndexForApprove" ? "active" : "")">
                <i class="bi bi-check"></i><span>Approve</span>
            </a>
        }

        @if (User.IsInRole("Requestor") || User.IsInRole("Approver") || User.IsInRole("Admin"))
        {
            <a asp-controller="SourceList" asp-action="AllSourceList"
               class="@(currentController == "SourceList" && currentAction == "AllSourceList" ? "active" : "")">
                <i class="bi bi-list-ul"></i><span>All Source List</span>
            </a>
        }

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="ManageUser"
               class="@(currentController == "Admin" && currentAction == "ManageUser" ? "active" : "")">
                <i class="bi bi-people"></i><span>Manage User</span>
            </a>
            <a asp-controller="Admin" asp-action="ManageSupplier"
               class="@(currentController == "Admin" && currentAction == "ManageSupplier" ? "active" : "")">
                <i class="bi bi-building-gear"></i><span>Manage Supplier</span>
            </a>
        }

        <a id="logoutLink" asp-controller="Account" asp-action="Logout">
            <i class="bi bi-box-arrow-right"></i><span>Logout</span>
        </a>
    </nav>

    <div class="main-content">
        <div class="topbar">
            <button id="sidebarToggle" class="sidebar-toggle-btn" aria-label="Toggle sidebar">
                <i class="bi bi-list"></i>
            </button>
            <div class="text-muted">
                <span>Logged in as: <strong>@User.Identity.Name</strong></span>
            </div>
        </div>
        <div class="container-fluid">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> @RenderSection("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
       
             const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('sidebarToggle');
            if(toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    sidebar.classList.toggle('closed');
                });
            }

            const logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function (event) {
                    event.preventDefault();
                    const logoutUrl = this.href;
                    Swal.fire({
                        title: 'Konfirmasi Logout', text: "Apakah Anda yakin ingin keluar?", icon: 'warning',
                        showCancelButton: true, confirmButtonColor: '#006400', cancelButtonColor: '#d33',
                        confirmButtonText: 'Ya, Keluar!', cancelButtonText: 'Batal'
                    }).then((result) => {
                        if (result.isConfirmed) { window.location.href = logoutUrl; }
                    });
                });
            }
        });
    </script>

    @* SweetAlert notification script *@
    @{
        var alertType = TempData["SweetAlertType"]?.ToString() ?? "info";
        var alertTitle = alertType switch
        {
            "success" => "Success!",
            "error" => "Oops!",
            "warning" => "Warning!",
            _ => "Info"
        };
    }
    @if (TempData["SweetAlertMessage"] != null)
    {
        <script>
            Swal.fire({
                title: '@alertTitle',
                text: '@Html.Raw(TempData["SweetAlertMessage"])',
                icon: '@alertType',
                confirmButtonText: 'OK'
            });
        </script>
    }
</body>
</html>