@model sourcelist.Services.PagedResult<sourcelist.DTOs.UserDTO>

@{
    ViewData["Title"] = "Manage User";
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    string searchTerm = ViewBag.SearchTerm as string ?? "";
    int totalRows = ViewBag.TotalRows ?? 0;
    int totalPages = totalRows > 0 ? (int)Math.Ceiling((double)totalRows / pageSize) : 1;
    int startRow = (page - 1) * pageSize + 1;
    int endRow = startRow + Model.Data.Count() - 1;

    // Logika untuk menampilkan tombol halaman
    int maxPagesToShow = 5;
    int startPage = Math.Max(1, page - maxPagesToShow / 2);
    int endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);
    startPage = Math.Max(1, endPage - maxPagesToShow + 1);
}
@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<style>
        .tableheader th {
            background-color: #a3d65c;
            color: white;
            border-color: #8dbb4c; 
        }

        .form-header {
            background: #a3d65c;
            color: #fff;
            padding: 10px;
            border-radius: 6px;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 18px;
            letter-spacing: 0.5px;
            margin-top:12px;
        }

        .tableheader th {
            background-color: #a3d65c;
            color: white;
            border-color: #8dbb4c;
        }

         
            .tableheader th:first-child {
                border-top-left-radius: 10px;
            }

            .tableheader th:last-child {
                border-top-right-radius: 10px;
            }

        .form-header {
            background: #a3d65c;
            color: #fff;
            padding: 10px;
            border-radius: 6px;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 18px;
            letter-spacing: 0.5px;
            margin-top: 12px;
        }

        .is-invalid {
            border-color: #dc3545 !important;
            box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25) !important;
        }
     
</style>
}

<div class="container-fluid" style="font-family:Calibri;">

        <div class="form-header">
        <i class="bi bi-people"></i>User List
        </div>

        <div class="card-body">
            <div class="row mb-3">
                    <div class="col-md-6">
                        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createUserModal">
                            <i class="bi bi-plus-circle"></i> Create User
                        </button>
                    </div>
                    <div class="col-md-6 text-md-end mt-2 mt-md-0">
                        <form asp-action="ManageUser" asp-controller="Admin" method="get">
                    <input type="text" id="searchBox" class="form-control" placeholder="Search by username or Email ... " name="searchTerm" value="@searchTerm" autocomplete="off">
                        </form>
                    </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover " width="100%" cellspacing="0">
                    <thead class="tableheader">
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data != null && Model.Data.Any())
                        {
                            foreach (var user in Model.Data)
                            {
                                <tr>
                                    <td>@user.Username</td>
                                    <td>@user.Email</td>
                                    <td>@user.Role</td>
                                    <td>
                                        <span class="badge @(user.Status == "Aktif" ? "bg-success" : "bg-danger")">@user.Status</span>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-warning btn-sm btn-edit"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editUserModal"
                                                data-id="@user.ID_User"
                                                data-username="@user.Username"
                                                data-email="@user.Email"
                                                data-role="@user.Role"
                                                data-status="@user.Status">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">User data not found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row mt-3">
                <div class="col-md-6">
                    @if (totalRows > 0)
                    {
                        <p class="text-muted">Showing @startRow to @endRow of @totalRows entries</p>
                    }
                </div>
                <div class="col-md-6">
                    @if (totalPages > 1)
                    {
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-end">
                                <li class="page-item @(page == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="ManageUser" asp-route-page="@(page - 1)" asp-route-searchTerm="@searchTerm">Previous</a>
                                </li>

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == page ? "active" : "")">
                                        <a class="page-link" asp-action="ManageUser" asp-route-page="@i" asp-route-searchTerm="@searchTerm">@i</a>
                                    </li>
                                }

                                <li class="page-item @(page == totalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="ManageUser" asp-route-page="@(page + 1)" asp-route-searchTerm="@searchTerm">Next</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel">New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="createForm" asp-action="CreateUser" asp-controller="Admin" method="post">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="username" name="Username" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email User</label>
                        <input type="email" class="form-control" id="email" name="Email" required>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Password User</label>
                        <input type="password" class="form-control" id="password" name="Password" required>
                    </div>
                    <div class="mb-3">
                        <label for="role" class="form-label">Role</label>
                        <select class="form-select" id="role" name="Role" required>
                            <option value="" selected disabled>-- Select Role --</option>
                            <option value="Requestor">Requestor</option>
                            <option value="Approver">Approver</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editUserModalLabel">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editForm" asp-action="EditUser" asp-controller="Admin" method="post">
                    <input type="hidden" id="edit-id" name="ID_User" />
                    <div class="mb-3">
                        <label for="edit-username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="edit-username" name="Username" required>
                    </div>
                    <div class="mb-3">
                        <label for="edit-email" class="form-label">Email User</label>
                        <input type="email" class="form-control" id="edit-email" name="Email" required>
                    </div>
                    <div class="mb-3">
                        <label for="edit-password" class="form-label">New Password</label>
                        <input type="password" class="form-control" id="edit-password" name="Password" placeholder="leave empaty to keep current value.">
                    </div>
                    <div class="mb-3">
                        <label for="edit-role" class="form-label">Role</label>
                        <select class="form-select" id="edit-role" name="Role" required>
                            <option value="Requestor">Requestor</option>
                            <option value="Approver">Approver</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="edit-status" class="form-label">Status</label>
                        <select class="form-select" id="edit-status" name="Status" required>
                            <option value="Aktif">Aktif</option>
                            <option value="Non-Aktif">Non-Aktif</option>
                        </select>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

        
            function resetForm(formId) {
                const form = document.getElementById(formId);
                if (form) {
                    form.reset();
                    form.querySelectorAll('.form-control, .form-select').forEach(el => {
                        el.classList.remove('is-invalid');
                    });
                }
            }

            var editUserModal = document.getElementById('editUserModal');
            editUserModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                editUserModal.querySelector('#edit-id').value = button.getAttribute('data-id');
                editUserModal.querySelector('#edit-username').value = button.getAttribute('data-username');
                editUserModal.querySelector('#edit-email').value = button.getAttribute('data-email');
                editUserModal.querySelector('#edit-role').value = button.getAttribute('data-role');
                editUserModal.querySelector('#edit-status').value = button.getAttribute('data-status');
                editUserModal.querySelector('#edit-password').value = "";
            });

            //  AJAX Handler untuk Create & Edit
            function handleUserSubmit(formId, confirmTitle) {
                const form = document.getElementById(formId);
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    // Bersihkan tanda merah sebelumnya
                    form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

                    Swal.fire({
                        title: confirmTitle,
                        text: "Are you sure you want to proceed?",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#28a745',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Yes, Save!',
                        cancelButtonText: 'No, Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            const formData = new FormData(form);
                            fetch(form.action, { method: 'POST', body: formData })
                            .then(res => res.json())
                            .then(data => {
                                if (data.success) {
                                    Swal.fire('Success!', data.message, 'success').then(() => location.reload());
                                } else {
                                    Swal.fire('Failed!', data.message, 'error');

                                    // BORDER MERAH
                                    const msg = data.message.toLowerCase();
                                    if (msg.includes("username")) {
                                        form.querySelector('[name="Username"]').classList.add('is-invalid');
                                    }
                                    if (msg.includes("email")) {
                                        form.querySelector('[name="Email"]').classList.add('is-invalid');
                                    }
                                }
                            });
                        }
                        else if (result.dismiss === Swal.DismissReason.cancel) {
                            resetForm(formId);
                        }
                    });
                });
            }

            ['createUserModal', 'editUserModal'].forEach(id => {
                const modalEl = document.getElementById(id);
                if (modalEl) {
                    modalEl.addEventListener('hidden.bs.modal', function () {
                        resetForm(modalEl.querySelector('form').id);
                    });
                }
            });

            // Panggil Handler
            handleUserSubmit('createForm', 'Create New User');
            handleUserSubmit('editForm', 'Save User Changes');

            const searchBox = document.getElementById('searchBox');
            let debounceTimer;
            if (searchBox) {
                if (searchBox.value.length > 0) {
                    searchBox.focus();
                    const val = searchBox.value;
                    searchBox.value = '';
                    searchBox.value = val;
                }

                // LOGIKA DEBOUNCE SUBMIT
                searchBox.addEventListener('input', function () {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(() => {
                        sessionStorage.setItem('isSearching', 'true');
                        this.form.submit();
                    }, 500);
                });
            }

            //  Pastikan fokus kembali jika sedang searching
            if (sessionStorage.getItem('isSearching') === 'true') {
                searchBox.focus();
                sessionStorage.removeItem('isSearching');
            }
        });
    </script>
}