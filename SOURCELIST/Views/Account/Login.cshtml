@model sourcelist.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Source List</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --green-dark: #1a472a;
            --green-lime: #a3d154;
            --green-pale: #d4edda;
            --input-bg: #f1f3f5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #ffffff;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* ORNAMEN  */

        .blob-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .liquid-shape-main {
            position: absolute;
            top: -15vh;
            left: -10vw;
            width: 50vw;
            height: 90vh;
            background: linear-gradient(135deg, var(--green-lime) 0%, var(--green-dark) 100%);
            border-radius: 30% 70% 60% 40% / 30% 40% 60% 70%;
            transform: rotate(-10deg);
            box-shadow: 10px 10px 30px rgba(26, 71, 42, 0.15);
        }

        .liquid-shape-bg {
            position: absolute;
            top: -20vh;
            left: -12vw;
            width: 55vw;
            height: 95vh;
            background: var(--green-pale);
            border-radius: 35% 65% 55% 45% / 35% 45% 55% 65%;
            transform: rotate(-15deg);
            z-index: -1;
        }

        .liquid-shape-bottom {
            position: absolute;
            bottom: -20vh;
            left: -5vw;
            width: 30vw;
            height: 30vw;
            background: linear-gradient(45deg, var(--green-pale), var(--green-lime));
            border-radius: 40% 60% 30% 70% / 50% 30% 70% 50%;
            opacity: 0.8;
        }


        /* --- FORM LOGIN --- */
        .login-wrapper {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 1200px;
            display: flex;
            justify-content: flex-end;
            padding-right: 10%;
        }

        .form-content {
            width: 400px;
            text-align: center;
        }

        .login-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }

        .login-subtitle {
            color: #888;
            margin-bottom: 40px;
            font-size: 0.9rem;
        }

        .input-group {
            position: relative;
            margin-bottom: 25px;
        }

        .input-field {
            width: 100%;
            padding: 18px 25px 18px 55px;
            border: none;
            border-radius: 50px;
            background-color: var(--input-bg);
            font-size: 1rem;
            color: #444;
            outline: none;
            transition: 0.3s;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.02);
        }

            .input-field:focus {
                background-color: #fff;
                box-shadow: 0 0 0 3px rgba(163, 209, 84, 0.3);
            }

        .input-icon {
            position: absolute;
            left: 25px;
            top: 50%;
            transform: translateY(-50%);
            color: #999;
            font-size: 1.2rem;
        }

        /* Tombol Login */
        .btn-login {
            width: 100%;
            padding: 18px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(to right, var(--green-lime), var(--green-dark));
            color: white;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 1px;
            cursor: pointer;
            box-shadow: 0 10px 25px rgba(26, 71, 42, 0.25);
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .btn-login:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(26, 71, 42, 0.35);
            }

    </style>
</head>
<body>

    <div class="blob-container">
        <div class="liquid-shape-bg"></div>   <div class="liquid-shape-main"></div> <div class="liquid-shape-bottom"></div>
    </div>

    <div class="login-wrapper">
        <div class="form-content">
            <h2 class="login-title">User Login</h2>
            <p class="login-subtitle">Welcome to Source List System</p>

            <form action="/Account/Login" method="post">
                @Html.AntiForgeryToken()

                <div class="input-group">
                    <i class="bi bi-person-fill input-icon"></i>
                    <input type="email" class="input-field" name="Email" placeholder="Username" required>
                </div>

                <div class="input-group">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <input type="password" class="input-field" name="Password" placeholder="Password" required>
                </div>

                <button type="submit" class="btn-login">LOGIN</button>

            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const loginStatus = '@(TempData["LoginStatus"] as string)';

            if (loginStatus === 'Error') {
                Swal.fire({
                    icon: 'error',
                    title: 'Login Failed',
                    text: 'The username or password you entered is incorrect.',
                    confirmButtonColor: '#1a472a'
                });
            }
        });
    </script>
</body>
</html>
